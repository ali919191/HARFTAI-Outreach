# Copy this file to .env and fill in your real values. Never commit .env.

ZOHO_EMAIL=you@yourdomain.com
ZOHO_APP_PASSWORD=your-zoho-app-specific-password
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_IMAP_HOST=imap.zoho.com
ZOHO_IMAP_PORT=993

SENDER_NAME=Ali Syed
BUSINESS_ADDRESS=HARFT AI, Houston, TX
HARFT_PHONE=+1 832 847 7198

GOOGLE_SHEET_ID=your-google-sheet-id-from-the-sheet-url
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
SHEET_TAB_NAME=Outreach

# Public HTTPS URL where tracking_server.py is deployed (no trailing slash)
TRACKING_BASE_URL=https://your-tracking-server.example.com

# Wait days BETWEEN touches: e.g. 4,9 = follow-up 1 four days after the
# initial email, follow-up 2 nine days after follow-up 1.
FOLLOWUP_DAYS=4,9

# Days after the final follow-up with no response before it's marked
# "No Response - Parked" and removed from the active pipeline view.
PARK_AFTER_DAYS=5

# Optional. Free tier: 50 credits/month, no card required. Get one at
# hunter.io -- used by find_emails.py to find verified emails for
# contacts where we already know the name. Leave blank to skip.
HUNTER_API_KEY=ed379249c69ff9b7763a799e144ee81dddea21a5
